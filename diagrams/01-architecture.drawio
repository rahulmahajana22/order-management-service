        <mxCell id="21" value="&lt;b&gt;DispatcherServlet&lt;/b&gt;&lt;br&gt;Spring MVC Front Controller&lt;br&gt;Routes requests by URL + method" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="30" y="55" width="250" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="22" value="&lt;b&gt;OrderController&lt;/b&gt;&lt;br&gt;@RestController&lt;br&gt;POST /api/orders&lt;br&gt;GET  /api/orders/{id}&lt;br&gt;GET  /api/orders?status=&lt;br&gt;PATCH /{id}/status&lt;br&gt;DELETE /{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="330" y="45" width="230" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="23" value="&lt;b&gt;Bean Validation&lt;/b&gt;&lt;br&gt;@Valid | @NotNull&lt;br&gt;@Min | @NotEmpty&lt;br&gt;Validates all incoming DTOs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="620" y="55" width="230" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="24" value="&lt;b&gt;GlobalExceptionHandler&lt;/b&gt;&lt;br&gt;@RestControllerAdvice&lt;br&gt;404 ResourceNotFound → 404&lt;br&gt;BusinessException → 400&lt;br&gt;Validation → 400 with fields&lt;br&gt;Generic Exception → 500" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="910" y="45" width="250" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="25" value="HTTP/REST Interface — JSON  |  Content-Type: application/json  |  Port 8080  |  Isolation: READ_COMMITTED default" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;opacity=60;fontSize=11;fontStyle=2;" vertex="1" parent="20">
          <mxGeometry x="30" y="220" width="1180" height="40" as="geometry"/>
        </mxCell>

        <!-- ═══ SPRING APPLICATION CONTEXT ═══ -->
