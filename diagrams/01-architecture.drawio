        <mxCell id="41" value="&lt;b&gt;OrderStatusScheduler&lt;/b&gt;&lt;br&gt;@Scheduled&lt;br&gt;fixedRate = 300,000 ms (5 min)&lt;br&gt;─────────────────────&lt;br&gt;processPendingOrders()&lt;br&gt;Isolation: SERIALIZABLE&lt;br&gt;PENDING ➜ PROCESSING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="40">
