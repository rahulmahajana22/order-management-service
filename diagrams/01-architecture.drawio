          <mxGeometry x="60" y="200" width="1360" height="430" as="geometry"/>
        </mxCell>

        <!-- JwtAuthenticationFilter — spans full width, first in filter chain -->
        <mxCell id="80" value="&lt;b&gt;JwtAuthenticationFilter&lt;/b&gt;  (OncePerRequestFilter)&lt;br&gt;Extracts Bearer token · Validates JWT signature &amp; expiry · Populates SecurityContext · 401 on invalid/missing token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="30" y="48" width="1300" height="55" as="geometry"/>
        </mxCell>

        <!-- DispatcherServlet -->
        <mxCell id="21" value="&lt;b&gt;DispatcherServlet&lt;/b&gt;&lt;br&gt;Spring MVC Front Controller&lt;br&gt;Routes requests by URL + method" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="30" y="120" width="240" height="90" as="geometry"/>
        </mxCell>

        <!-- OrderController -->
        <mxCell id="22" value="&lt;b&gt;OrderController&lt;/b&gt;&lt;br&gt;@RestController&lt;br&gt;POST /api/orders&lt;br&gt;GET  /api/orders/{id}&lt;br&gt;GET  /api/orders?status=&amp;page=&lt;br&gt;PATCH /{id}/status&lt;br&gt;DELETE /{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="290" y="110" width="230" height="145" as="geometry"/>
        </mxCell>

        <!-- AuthController (NEW) -->
        <mxCell id="81" value="&lt;b&gt;AuthController&lt;/b&gt;&lt;br&gt;@RestController&lt;br&gt;POST /api/auth/login&lt;br&gt;POST /api/auth/register" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="540" y="110" width="210" height="145" as="geometry"/>
        </mxCell>

        <!-- Bean Validation -->
        <mxCell id="23" value="&lt;b&gt;Bean Validation&lt;/b&gt;&lt;br&gt;@Valid | @NotNull&lt;br&gt;@Min | @NotEmpty&lt;br&gt;@Email | @Size&lt;br&gt;Validates all incoming DTOs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="775" y="120" width="215" height="110" as="geometry"/>
        </mxCell>

        <!-- GlobalExceptionHandler -->
        <mxCell id="24" value="&lt;b&gt;GlobalExceptionHandler&lt;/b&gt;&lt;br&gt;@RestControllerAdvice&lt;br&gt;404 ResourceNotFound → 404&lt;br&gt;BusinessException → 400&lt;br&gt;Validation → 400 with fields&lt;br&gt;BadCredentials → 401&lt;br&gt;Generic Exception → 500" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="1010" y="110" width="260" height="145" as="geometry"/>
        </mxCell>

        <!-- HTTP/REST Interface note -->
        <mxCell id="25" value="HTTP/REST Interface — JSON  |  Content-Type: application/json  |  Port 8080  |  Isolation: READ_COMMITTED default  |  Rate-limited (Resilience4j)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;opacity=60;fontSize=11;fontStyle=2;" vertex="1" parent="20">
          <mxGeometry x="30" y="310" width="1300" height="40" as="geometry"/>
