        <!-- ═══ TITLE ═══ -->
        <mxCell id="2" value="Order Management System — System Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
