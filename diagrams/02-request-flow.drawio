<mxfile host="app.diagrams.net" version="21.0.0" type="device" compressed="false">
  <diagram id="request-flow" name="Request Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1800" math="0" shadow="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══ TITLE ═══ -->
        <mxCell id="2" value="Order Management System — API Request Flows" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="1000" height="40" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════════
             FLOW 1: CREATE ORDER
        ══════════════════════════════════════════════════ -->

        <mxCell id="100" value="FLOW 1 — POST /api/orders (Create Order)" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- START -->
        <mxCell id="101" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1ba1e2;strokeColor=#006EAF;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Client request -->
        <mxCell id="102" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;POST /api/orders&lt;br&gt;{ customerId: 1, items: [{productId:1, qty:2}] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="210" width="360" height="70" as="geometry"/>
        </mxCell>

        <!-- Controller -->
        <mxCell id="103" value="&lt;b&gt;OrderController.createOrder()&lt;/b&gt;&lt;br&gt;Receives HTTP POST request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="310" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- Validation diamond -->
        <mxCell id="104" value="@Valid&lt;br&gt;passes?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="400" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Validation fail -->
        <mxCell id="105" value="400 Bad Request&lt;br&gt;{ errors: { field: message } }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="415" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- Service call -->
        <mxCell id="106" value="&lt;b&gt;OrderService.createOrder()&lt;/b&gt;&lt;br&gt;@Transactional(READ_COMMITTED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="520" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- Find customer -->
        <mxCell id="107" value="customerRepository.findById(customerId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="620" width="360" height="50" as="geometry"/>
        </mxCell>

        <!-- Customer found? -->
        <mxCell id="108" value="Customer&lt;br&gt;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="700" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Customer not found -->
        <mxCell id="109" value="ResourceNotFoundException&lt;br&gt;→ 404 Customer not found" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="715" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- For each item -->
        <mxCell id="110" value="For each item in request.items:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="820" width="360" height="40" as="geometry"/>
        </mxCell>

        <!-- Find product -->
        <mxCell id="111" value="productRepository.findById(productId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="900" width="360" height="50" as="geometry"/>
        </mxCell>

        <!-- Product found? -->
        <mxCell id="112" value="Product&lt;br&gt;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="985" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Product not found -->
        <mxCell id="113" value="ResourceNotFoundException&lt;br&gt;→ 404 Product not found" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="1000" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- Calculate total -->
        <mxCell id="114" value="Create OrderItem (snapshot unitPrice = product.price)&lt;br&gt;totalAmount += qty × price" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="1110" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- Build order -->
        <mxCell id="115" value="Build Order entity&lt;br&gt;status = PENDING | createdAt = now()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="1210" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- Save order -->
        <mxCell id="116" value="orderRepository.save(order)&lt;br&gt;SQL: INSERT INTO orders + order_items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="1310" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- Map response -->
        <mxCell id="117" value="Map to OrderResponse&lt;br&gt;(id, customerName, status, totalAmount, items[])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="1410" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- Return -->
        <mxCell id="118" value="&lt;b&gt;Return 201 Created&lt;/b&gt;&lt;br&gt;{ OrderResponse JSON }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="1510" width="360" height="60" as="geometry"/>
        </mxCell>

        <!-- END -->
        <mxCell id="119" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1ba1e2;strokeColor=#006EAF;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="1610" width="160" height="50" as="geometry"/>
        </mxCell>

