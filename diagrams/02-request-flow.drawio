        <!-- ══════════════════════════════════════════════════
             FLOW 2: CANCEL ORDER
        ══════════════════════════════════════════════════ -->

        <mxCell id="200" value="FLOW 2 — DELETE /api/orders/{id} (Cancel Order)" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="70" width="580" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="201" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1ba1e2;strokeColor=#006EAF;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1070" y="130" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="202" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;DELETE /api/orders/1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="210" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="203" value="&lt;b&gt;OrderController.cancelOrder(id)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="310" width="280" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="204" value="&lt;b&gt;OrderService.cancelOrder(id)&lt;/b&gt;&lt;br&gt;REPEATABLE_READ isolation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="400" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="205" value="orderRepository.findById(id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="500" width="280" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="206" value="Order&lt;br&gt;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1060" y="590" width="140" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="207" value="404 Order not found" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1320" y="610" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="208" value="Status == PENDING?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1040" y="720" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="209" value="400 BusinessException&lt;br&gt;Only PENDING orders can be cancelled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1320" y="740" width="230" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="210" value="order.setStatus(CANCELLED)&lt;br&gt;orderRepository.save(order)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="850" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="211" value="&lt;b&gt;Return 200 OK&lt;/b&gt;&lt;br&gt;{ OrderResponse (status: CANCELLED) }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
